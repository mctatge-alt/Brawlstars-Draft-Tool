# Copy to .env and fill in. .env is gitignored — never commit your token.

# --- Brawl Stars official API (https://developer.brawlstars.com) ---
# Create a free account → "Create New Key". IMPORTANT: the key is locked to the
# IP address(es) you list when creating it. Use the public IP of the machine that
# runs the crawler (the portal shows your current IP). Re-issue if your IP changes.
BRAWLSTARS_API_TOKEN=

# --- Your player tag (for mastery personalization) ---
# Found in-game under your profile, e.g. #2YULP2RUV  (with or without the leading #)
PLAYER_TAG=

# Brawlify / BrawlAPI (reference data + images) is keyless — no token required.

# --- Crawler tuning ---
CRAWL_RATE_LIMIT_PER_SEC=5
CRAWL_SEED_COUNTRIES=global,US,DE,KR,BR,JP
CRAWL_RANKED_ONLY=true

# --- Cloud serving / live refresh (only the deployed API needs these; set via render.yaml) ---
# URL of the published matches dataset (GitHub Release asset, gzipped). When set, the API
# syncs it at startup and every REFRESH_SECONDS and rebuilds stats with no restart. Leave
# unset for local dev (the app then just reads data/raw/matches.jsonl).
# DATA_URL=https://github.com/<owner>/<repo>/releases/download/data-latest/matches.jsonl.gz
# REFRESH_SECONDS=600
